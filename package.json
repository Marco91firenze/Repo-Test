{
  "name": "cv-fit-check",
  "version": "1.0.0",
  "description": "Privacy-first CV ranking tool with local AI analysis",
  "main": "dist-electron/main.js",
  "author": "Marco91firenze",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:landing": "BUILD_TARGET=landing vite build",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder"
  },
  "build": {
    "appId": "com.cvfit.check",
    "productName": "CV Fit Check",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "CV-Fit-Check-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "releaseType": "release",
      "provider": "github",
      "owner": "Marco91firenze",
      "repo": "Repo-Test"
    }
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "@electron/rebuild": "^4.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.31.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "uuid": "^13.0.0",
    "vite": "^5.4.2"
  }
}
